{
  "cli": {
    "version": ">= 12.0.0",
    "requireCommit": true
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "public": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "production"
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}